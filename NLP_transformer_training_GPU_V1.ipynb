    "def eng_to_spa():\n",
    "  \"\"\"Function to provide iterator for tokenizer\"\"\"\n",
    "  for pair in nmt_train_set:\n",
    "    yield pair[\"source_text\"]\n",
    "    yield pair[\"target_text\"]"
   ]
